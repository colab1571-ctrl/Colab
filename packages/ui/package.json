{
  "name": "@colab/ui",
  "version": "0.1.0",
  "description": "Colab shared UI component library — shadcn-based, Tailwind v4",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./theme": "./src/theme/ThemeProvider.tsx",
    "./auth": "./src/auth/AuthProvider.tsx"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "next": ">=15.0.0",
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true }
  },
  "devDependencies": {
    "@colab/design-tokens": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "next": "^15.1.6",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.474.0",
    "tailwind-merge": "^2.6.0"
  }
}
