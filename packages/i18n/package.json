{
  "name": "@colab/i18n",
  "version": "0.1.0",
  "description": "Colab locale catalogs and i18n loader utility",
  "private": true,
  "type": "module",
  "main": "./src/loader.ts",
  "exports": {
    ".": "./src/loader.ts",
    "./locales/*": "./locales/*",
    "./src/init": "./src/init.ts",
    "./src/init-rn": "./src/init-rn.ts",
    "./src/types": "./src/types.ts",
    "./src/useLocale": "./src/useLocale.ts"
  },
  "files": ["src", "locales", "scripts"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linting for i18n catalogs'",
    "generate-pseudo": "node scripts/generate-pseudo.mjs"
  },
  "dependencies": {
    "i18next": "^26.1.0",
    "react-i18next": "^15.2.0",
    "i18next-icu": "^2.3.0",
    "i18next-http-backend": "^2.7.0",
    "i18next-browser-languagedetector": "^8.0.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.73",
    "i18n-js": "^4.4.3",
    "react-native-localize": "^3.2.2",
    "@react-native-async-storage/async-storage": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "react-native": { "optional": true },
    "i18n-js": { "optional": true },
    "react-native-localize": { "optional": true },
    "@react-native-async-storage/async-storage": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
