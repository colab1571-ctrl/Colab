{
  "name": "@colab/i18n",
  "version": "0.1.0",
  "description": "Colab locale catalogs and i18n loader utility",
  "private": true,
  "type": "module",
  "main": "./src/loader.ts",
  "exports": {
    ".": "./src/loader.ts",
    "./locales/*": "./locales/*"
  },
  "files": ["src", "locales"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linting for i18n catalogs'"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
