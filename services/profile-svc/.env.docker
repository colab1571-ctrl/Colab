# profile-svc Docker environment
ENV=local
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://colab:colab@postgres:5432/profile_svc

# Redis (db 2 for profile)
REDIS_URL=redis://redis:6379/2

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# AWS (localstack)
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localstack:4566

# S3
S3_PORTFOLIO_BUCKET=colab-portfolio-dev
S3_REGION=us-east-1

# KMS
KMS_KEY_ID_TOKENS=alias/colab-oauth-tokens-dev

# Internal services
MODERATION_SVC_URL=http://moderation-svc:8000
GEO_SVC_URL=http://geo-svc:8000
NOTIFICATION_SVC_URL=http://notification-svc:8000

# Service-to-service auth
INTERNAL_SERVICE_SECRET=dev-secret-change-me

# OAuth providers (empty for local)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# App domain
APP_DOMAIN=https://app.colab.local

# OpenAI (empty for local)
OPENAI_API_KEY=sk-local-placeholder
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536
