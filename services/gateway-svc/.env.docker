# gateway-svc Docker environment
ENV=local
LOG_LEVEL=INFO

# Database (gateway has a small waitlist table)
DATABASE_URL=postgresql+asyncpg://colab:colab@postgres:5432/gateway_svc

# Redis (db 0 for gateway rate limiting)
REDIS_URL=redis://redis:6379/0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# AWS (localstack)
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localstack:4566

# App domains
APP_DOMAIN=app.colab.local
MARKETING_DOMAIN=colab.local
ADMIN_DOMAIN=admin.colab.local

# Upstream service URLs (Docker internal)
UPSTREAM_AUTH_URL=http://auth-svc:8000
UPSTREAM_PROFILE_URL=http://profile-svc:8000
UPSTREAM_IDENTITY_URL=http://identity-svc:8000
UPSTREAM_DISCOVERY_URL=http://discovery-svc:8000
UPSTREAM_MATCHING_URL=http://matching-svc:8000
UPSTREAM_INVITE_URL=http://invite-svc:8000
UPSTREAM_COLLAB_URL=http://collab-svc:8000
UPSTREAM_CHAT_URL=http://chat-svc:8000
UPSTREAM_MEDIA_URL=http://media-svc:8000
UPSTREAM_AI_URL=http://ai-orchestrator-svc:8000
UPSTREAM_MODERATION_URL=http://moderation-svc:8000
UPSTREAM_NOTIFICATION_URL=http://notification-svc:8000
UPSTREAM_BILLING_URL=http://billing-svc:8000
UPSTREAM_SUPPORT_URL=http://support-svc:8000
UPSTREAM_ADMIN_URL=http://admin-svc:8000
UPSTREAM_GEO_URL=http://geo-svc:8000
UPSTREAM_MEETING_URL=http://meeting-svc:8000
UPSTREAM_ANALYTICS_URL=http://analytics-svc:8000
UPSTREAM_HELLO_URL=http://hello-svc:8000

# JWT verification
JWT_ALGORITHM=HS256
JWT_SECRET_KEY=dev-jwt-secret-change-in-production-must-be-long-enough
