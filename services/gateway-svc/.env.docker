# gateway-svc Docker environment
# Used by docker-compose; docker-internal hostnames

ENV=local
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://colab:colab@postgres:5432/colab_dev

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=dev-secret-change-in-prod

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# AWS / LocalStack
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localstack:4566

# Upstream service URLs (docker-internal)
UPSTREAM_AUTH_URL=http://auth-svc:8001
UPSTREAM_PROFILE_URL=http://profile-svc:8002
UPSTREAM_DISCOVERY_URL=http://discovery-svc:8003
UPSTREAM_CHAT_URL=http://chat-svc:8004
UPSTREAM_IDENTITY_URL=http://auth-svc:8001
UPSTREAM_MATCHING_URL=http://discovery-svc:8003
UPSTREAM_INVITE_URL=http://discovery-svc:8003
UPSTREAM_COLLAB_URL=http://discovery-svc:8003
UPSTREAM_MEDIA_URL=http://profile-svc:8002
UPSTREAM_AI_URL=http://discovery-svc:8003
UPSTREAM_MODERATION_URL=http://discovery-svc:8003
UPSTREAM_NOTIFICATION_URL=http://discovery-svc:8003
UPSTREAM_BILLING_URL=http://discovery-svc:8003
UPSTREAM_SUPPORT_URL=http://discovery-svc:8003
UPSTREAM_ADMIN_URL=http://discovery-svc:8003
UPSTREAM_GEO_URL=http://discovery-svc:8003
UPSTREAM_MEETING_URL=http://discovery-svc:8003
UPSTREAM_ANALYTICS_URL=http://discovery-svc:8003
UPSTREAM_HELLO_URL=http://discovery-svc:8003

# App domains (dev)
APP_DOMAIN=localhost
MARKETING_DOMAIN=localhost
ADMIN_DOMAIN=localhost
API_DOMAIN=localhost

GIT_SHA=dev
IMAGE_TAG=dev
