{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noUncheckedIndexedAccess": false,
    "composite": false,
    "incremental": false,
    "types": ["node", "jest", "@testing-library/jest-native"],
    "paths": {
      "@colab/api-types/*": ["../../packages/api-types/*"],
      "@colab/i18n": ["../../packages/i18n/src/loader.ts"]
    }
  },
  "include": ["src", "src/__tests__", "app.config.ts", "babel.config.js"],
  "exclude": ["node_modules"]
}
