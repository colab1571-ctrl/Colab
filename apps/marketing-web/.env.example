# marketing-web environment variables
# Copy to .env.local for local development. Never commit .env.local.
# See plan/appendix-B for full documentation.

# ── Public (exposed to browser) ────────────────────────────────────────────

# Full URL of the marketing site (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://colabclub.net

# Brand name token — replace with final brand name before launch
NEXT_PUBLIC_BRAND_NAME=<BRAND_NAME>

# App Store / Play Store URLs (leave empty until stores go live — badges are hidden)
NEXT_PUBLIC_APP_STORE_URL=
NEXT_PUBLIC_PLAY_STORE_URL=

# PostHog analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Social links (used in JSON-LD Organization schema)
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TWITTER_URL=

# ── Server-only (not exposed to browser) ──────────────────────────────────

# AWS SES contact list for waitlist emails
WAITLIST_LIST_NAME=colab-waitlist-prod
AWS_REGION=us-east-1

# Postgres connection string (for waitlist_emails row write)
DATABASE_URL=postgresql://user:password@localhost:5432/colab
