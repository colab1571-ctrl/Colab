# Colab — environment variable template
# Copy to `.env` for local dev. Never commit `.env`.
# Production: read from AWS Secrets Manager via IRSA.

# =========================================================================
# Application
# =========================================================================
NODE_ENV=development
ENV=local                            # local | dev | staging | prod
LOG_LEVEL=debug
BRAND_NAME=Colab                     # Single source of truth for user-facing name; swap at launch
APP_DOMAIN=app.colab.test
MARKETING_DOMAIN=colab.test
ADMIN_DOMAIN=admin.colab.test
API_DOMAIN=api.colab.test

# =========================================================================
# AWS
# =========================================================================
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
AWS_PROFILE=colab-admin              # Local CLI profile, NOT for production pods

# RDS Postgres
DATABASE_URL=postgresql://colab:colab@localhost:5432/colab
DATABASE_REPLICA_URL=                # Optional read replica
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=50

# ElastiCache Redis
REDIS_URL=redis://localhost:6379/0
REDIS_TLS=false

# S3 buckets (one per category; production names include env suffix)
S3_BUCKET_PORTFOLIO=colab-portfolio-dev
S3_BUCKET_CHAT_FILES=colab-chat-files-dev
S3_BUCKET_AUDIT_LOGS=colab-audit-logs-dev
S3_BUCKET_MOCKUP_ASSETS=colab-mockup-assets-dev
S3_BUCKET_WEB_STATIC=colab-web-static-dev
CLOUDFRONT_DISTRIBUTION_ID=
CLOUDFRONT_DOMAIN=

# Amazon MQ for RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# AWS SES (transactional email)
SES_FROM_ADDRESS=no-reply@colab.test
SES_REPLY_TO_ADDRESS=support@colab.test

# AWS SNS Mobile Push
SNS_APNS_ARN=
SNS_FCM_ARN=

# =========================================================================
# Auth
# =========================================================================
JWT_SECRET=                          # 32-byte random; production from Secrets Manager
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000      # 30 days

# Apple Sign-In
APPLE_TEAM_ID=
APPLE_BUNDLE_ID=com.colabtest.colab
APPLE_KEY_ID=                        # APNs key id
APPLE_PRIVATE_KEY=                   # .p8 contents (newline-escaped)
APPLE_SIGN_IN_CLIENT_ID=

# Google Sign-In
GOOGLE_CLIENT_ID_IOS=
GOOGLE_CLIENT_ID_ANDROID=
GOOGLE_CLIENT_ID_WEB=
GOOGLE_CLIENT_SECRET_WEB=
GOOGLE_SERVICE_ACCOUNT_JSON=         # Base64-encoded JSON; used for server-side Calendar + YouTube

# Phone OTP via AWS SNS SMS
SNS_SMS_SENDER_ID=Colab
SNS_SMS_TYPE=Transactional

# =========================================================================
# Identity / Persona
# =========================================================================
PERSONA_API_KEY=
PERSONA_TEMPLATE_ID=
PERSONA_WEBHOOK_SECRET=

# =========================================================================
# Payments
# =========================================================================
# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PREMIUM_MONTH=
STRIPE_PRICE_ID_PREMIUM_YEAR=
STRIPE_PRICE_ID_PRO_MONTH=
STRIPE_PRICE_ID_PRO_YEAR=
STRIPE_PRICE_ID_CREDITS_SMALL=
STRIPE_PRICE_ID_CREDITS_MEDIUM=
STRIPE_PRICE_ID_CREDITS_LARGE=

# RevenueCat
REVENUECAT_API_KEY_IOS=              # RN public key
REVENUECAT_API_KEY_ANDROID=          # RN public key
REVENUECAT_SECRET_KEY=               # Server-side
REVENUECAT_WEBHOOK_SECRET=

# =========================================================================
# AI providers
# =========================================================================
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_MODEL_MAIN=gpt-4.1            # Default model for matching/assistant/summaries
OPENAI_MODEL_MOD=omni-moderation-latest
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

REPLICATE_API_TOKEN=
REPLICATE_WEBHOOK_SECRET=
REPLICATE_MODEL_IMAGE_BASIC=
REPLICATE_MODEL_IMAGE_PRO=
REPLICATE_MODEL_AUDIO_BASIC=
REPLICATE_MODEL_AUDIO_PRO=

RECALL_API_TOKEN=
RECALL_WEBHOOK_SECRET=

# =========================================================================
# Geo
# =========================================================================
MAPBOX_SECRET_TOKEN=
MAPBOX_PUBLIC_TOKEN=

# =========================================================================
# Social OAuth (linking, not signup)
# =========================================================================
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

YOUTUBE_API_KEY=                     # Google Cloud project; also covered by GOOGLE_SERVICE_ACCOUNT_JSON

# =========================================================================
# Observability
# =========================================================================
SENTRY_DSN_API=
SENTRY_DSN_RN=
SENTRY_DSN_CONSUMER_WEB=
SENTRY_DSN_ADMIN=
SENTRY_DSN_MARKETING=

POSTHOG_API_KEY_MOBILE=
POSTHOG_API_KEY_WEB=
POSTHOG_HOST=https://us.i.posthog.com

# =========================================================================
# CI / EAS
# =========================================================================
EXPO_TOKEN=

# =========================================================================
# Feature flags / runtime config (read by gateway-svc, exposed to clients)
# =========================================================================
FEATURE_AI_MOCKUPS_ENABLED=true
FEATURE_IN_CHAT_AI_ENABLED=true
FEATURE_ADS_ENABLED=false            # Journey D deferred this milestone
FEATURE_MARKETING_NOTIFICATIONS=false
FEATURE_REGION_ALLOWLIST=US,CA,AU,NZ,IN

# =========================================================================
# Rate limits (admin-tunable; defaults from spec)
# =========================================================================
RATE_LIMIT_AUTH_PER_IP_PER_MIN=10
RATE_LIMIT_INVITE_FREE_PER_WEEK=5
RATE_LIMIT_FEED_PROFILES_FREE_PER_DAY=30
